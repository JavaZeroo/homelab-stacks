# ─── 全局 ─────────────────────────────────────────────
PUID=0
PGID=0
TZ=Asia/Shanghai

# ─── docker-stack (Portainer / Watchtower) ────────────
DOCKER_STACK_ROOT=/data/apps

# ─── media ────────────────────────────────────────────
MEDIA_STACK_ROOT=/data/apps

# qBittorrent
QBIT_PORT_UI=8080
QBIT_PORT_CONN=51324

# MoviePilot
MOVIEPILOT_PORT=3000
MOVIEPILOT_API_PORT=3001
MOVIEPILOT_SUPERUSER=admin
MOVIEPILOT_DB_PASSWORD=pg_password          # ← 务必修改
MOVIEPILOT_REDIS_PASSWORD=redis_password    # ← 务必修改

# Jellyfin
JELLYFIN_PORT_HTTP=8096

# Jellyseerr
JELLYSEERR_PORT=5055

# Metatube
METATUBE_PORT=19225
METATUBE_DB_PASSWORD=metatube

# ─── sub-store ────────────────────────────────────────
SUB_STORE_PORT=13003
SUB_STORE_BACKEND_PATH=/Ku91677Gk7fHKlMQagFl

# ─── valheim-server ──────────────────────────────────
TZ=Asia/Taipei                              # Valheim 单独时区
VALHEIM_SERVER_NAME=JavaZero Server
VALHEIM_WORLD_NAME=wtfsbsbsbsb
VALHEIM_SERVER_PASS=07551234                # ← 务必修改
VALHEIM_SERVER_PUBLIC=true
